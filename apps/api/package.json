{
  "name": "@cip/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "webhook:promptpay": "tsx src/scripts/send-promptpay-webhook.ts",
    "match:promptpay": "tsx src/scripts/match-promptpay-transactions.ts",
    "match:kbiz": "tsx src/scripts/match-kbiz-statement.ts",
    "test": "node --test --experimental-strip-types src/**/*.test.ts"
  },
  "dependencies": {
    "@cip/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "express": "^5.1.0",
    "mysql2": "^3.15.0",
    "nodemailer": "^7.0.5",
    "qrcode": "^1.5.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.1",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.6",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
